# Path to the UK Road Safety dataset (.csv or .xlsx). Relative to backend/.
ACCIDENTS_DATASET_PATH="data/Accident_Information.csv.xlsx"

# If true, accidents collection is re-imported on startup when it is empty.
IMPORT_ACCIDENTS_ON_STARTUP=true
ACCIDENTS_IMPORT_BATCH_SIZE=5000

# Path to the trained risk model, loaded once on startup.
RISK_MODEL_PATH="data/road_risk_model.pkl"

# OpenWeatherMap — get a free key at https://home.openweathermap.org/api_keys
