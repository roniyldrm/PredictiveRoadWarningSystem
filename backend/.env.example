# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="roadsense"

# JWT settings (used by /api/auth/*). Use a long random value in production.
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=1440

# CORS: comma-separated origins, or "*" (dev only, disables credentials).
# Examples for Expo/React Native + web: "http://localhost:19006,exp://127.0.0.1:19000"
CORS_ALLOW_ORIGINS="*"

# Path to the UK Road Safety dataset (.csv or .xlsx). Relative to backend/.
ACCIDENTS_DATASET_PATH="data/Accident_Information.csv.xlsx"

# If true, accidents collection is re-imported on startup when it is empty.
IMPORT_ACCIDENTS_ON_STARTUP=true
ACCIDENTS_IMPORT_BATCH_SIZE=5000

# Path to the trained risk model, loaded once on startup.
RISK_MODEL_PATH="data/road_risk_model.pkl"

# OpenWeatherMap — https://home.openweathermap.org/api_keys
# Required by POST /api/predict-risk to fetch real-time rain / wind / visibility.
OPENWEATHERMAP_API_KEY=""
OPENWEATHERMAP_TIMEOUT_SECONDS=4.0
# Cache radius (decimal degrees) and TTL (seconds) for weather fetches.
# ~0.02 deg ≈ 2 km — fine enough for risk, coarse enough to hit the cache.
WEATHER_CACHE_RESOLUTION_DEG=0.02
WEATHER_CACHE_TTL_SECONDS=300

# Trust X-Forwarded-* headers when running behind an HTTPS-terminating proxy.
TRUST_PROXY_HEADERS=true
